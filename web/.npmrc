# Next.js standalone output uses node-file-trace, which can't follow
# pnpm's default symlinked store layout — it silently misses transitive
# deps like @swc/helpers and the standalone bundle then crashes at
# runtime with "Cannot find module '@swc/helpers/_/_interop_require_default'".
# Forcing a flat node_modules costs install speed but lets nft trace
# correctly across the dep graph.
node-linker=hoisted
